# Server
NODE_ENV=development
PORT=4000

# API
API_PREFIX=/api/v1

# Database (PostgreSQL)
# Option A (preferred): a single connection string. Special characters in the
# password must be URL-encoded (e.g. & -> %26, * -> %2A).
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Option B: discrete settings (used only when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=be_god_peoples
DB_USER=postgres
DB_PASSWORD=
# Set to true to auto-sync models to the schema on boot (dev only; use migrations in prod)
DB_SYNC=false

# File uploads (maximum upload size in megabytes)
MAX_FILE_SIZE_MB=100
